<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gold Pouch - Premium Affiliate & Lifestyle Blog</title>
    <link rel="stylesheet" href="CSS/styles.css">
    <link rel="stylesheet" href="CSS/animations.css">
    <link rel="stylesheet" href="CSS/responsive.css">
</head>
<body>
    <!-- Background animated elements -->
    <div class="background-container">
        <canvas id="heartbeatCanvas"></canvas>
        <div class="neon-grid"></div>
        <div class="animated-orbs">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>
        </div>
    </div>

    <!-- Header -->
    <header class="header">
        <div class="header-content">
            <div class="logo-wrapper">
                <div class="logo-text">
                    <span class="gold-text">GOLD</span>
                    <span class="heart-icon">❤️</span>
                    <span class="red-text">POUCH</span>
                </div>
                <p class="tagline">Premium Affiliate & Lifestyle Insights</p>
            </div>
            <nav class="nav-menu">
                <a href="#ecommerce" class="nav-link">Shop</a>
                <a href="#blog" class="nav-link">Blog</a>
                <a href="#about" class="nav-link">About</a>
                <a href="#contact" class="nav-link">Contact</a>
            </nav>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="hero-title">
                <span class="title-word" data-word="Elevate">Elevate</span>
                <span class="title-word" data-word="Your">Your</span>
                <span class="title-word" data-word="Lifestyle">Lifestyle</span>
            </h1>
            <p class="hero-subtitle">Curated premium products & exclusive insights for the modern you</p>
            <button class="cta-button primary-btn">Explore Now</button>
        </div>
    </section>

    <!-- E-Commerce Section (Top) -->
    <section id="ecommerce" class="ecommerce-section">
        <div class="section-header">
            <h2 class="section-title">Premium Products</h2>
            <p class="section-subtitle">Discover our exclusive collection</p>
        </div>

        <div class="products-grid">
            <div class="product-card">
                <div class="product-image" style="background: linear-gradient(135deg, #ffdf00, #d4af37);">
                    <span class="product-badge">Best Seller</span>
                </div>
                <div class="product-info">
                    <h3 class="product-title">Premium Gold Pack</h3>
                    <p class="product-description">Exclusive gold collection with premium benefits</p>
                    <div class="product-footer">
                        <span class="product-price">$99.99</span>
                        <button class="product-btn" onclick="openProductOverlay(0)">View Details</button>
                    </div>
                </div>
            </div>

            <div class="product-card">
                <div class="product-image" style="background: linear-gradient(135deg, #d4af37, #b8860b);">
                    <span class="product-badge">Hot Deal</span>
                </div>
                <div class="product-info">
                    <h3 class="product-title">Luxury Chrome Bundle</h3>
                    <p class="product-description">Complete bundle with premium features and support</p>
                    <div class="product-footer">
                        <span class="product-price">$149.99</span>
                        <button class="product-btn" onclick="openProductOverlay(1)">View Details</button>
                    </div>
                </div>
            </div>

            <div class="product-card">
                <div class="product-image" style="background: linear-gradient(135deg, #dc143c, #ff6b6b);">
                    <span class="product-badge">New</span>
                </div>
                <div class="product-info">
                    <h3 class="product-title">Red Chrome Elite</h3>
                    <p class="product-description">Ultimate premium experience with elite features</p>
                    <div class="product-footer">
                        <span class="product-price">$199.99</span>
                        <button class="product-btn" onclick="openProductOverlay(2)">View Details</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="see-more-container">
            <button class="see-more-btn" onclick="openEcommerceOverlay()">See More Products</button>
        </div>
    </section>

    <!-- Blog Section -->
    <section id="blog" class="blog-section">
        <div class="section-header">
            <h2 class="section-title">Latest Blog Posts</h2>
            <p class="section-subtitle">Insights and tips for success</p>
        </div>

        <div class="blog-grid">
            <article class="blog-card">
                <div class="blog-image" style="background: linear-gradient(135deg, #ffdf00, #fff4cc);">
                    <span class="blog-category">Affiliate Marketing</span>
                </div>
                <div class="blog-content">
                    <h3 class="blog-title">Mastering Affiliate Marketing in 2024</h3>
                    <p class="blog-excerpt">Learn the secrets to building a successful affiliate marketing business with proven strategies...</p>
                    <div class="blog-meta">
                        <span class="blog-date">Dec 15, 2024</span>
                        <button class="blog-link" onclick="openBlogOverlay(0)">Read More</button>
                    </div>
                </div>
            </article>

            <article class="blog-card">
                <div class="blog-image" style="background: linear-gradient(135deg, #d4af37, #b8860b);">
                    <span class="blog-category">Tips & Tricks</span>
                </div>
                <div class="blog-content">
                    <h3 class="blog-title">10 Premium Strategies for Content Success</h3>
                    <p class="blog-excerpt">Discover the top strategies used by successful content creators to maximize engagement and conversions...</p>
                    <div class="blog-meta">
                        <span class="blog-date">Dec 12, 2024</span>
                        <button class="blog-link" onclick="openBlogOverlay(1)">Read More</button>
                    </div>
                </div>
            </article>

            <article class="blog-card">
                <div class="blog-image" style="background: linear-gradient(135deg, #dc143c, #ff6b6b);">
                    <span class="blog-category">Industry News</span>
                </div>
                <div class="blog-content">
                    <h3 class="blog-title">The Future of Online Business: Trends to Watch</h3>
                    <p class="blog-excerpt">Stay ahead of the curve with insights into emerging trends that will shape the digital landscape...</p>
                    <div class="blog-meta">
                        <span class="blog-date">Dec 10, 2024</span>
                        <button class="blog-link" onclick="openBlogOverlay(2)">Read More</button>
                    </div>
                </div>
            </article>
        </div>

        <div class="see-more-container">
            <button class="see-more-btn" onclick="openBlogListOverlay()">See More Articles</button>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact-section">
        <div class="section-header">
            <h2 class="section-title">Get In Touch</h2>
            <p class="section-subtitle">We'd love to hear from you</p>
        </div>
        <form class="contact-form" id="contactForm">
            <input type="text" placeholder="Your Name" required>
            <input type="email" placeholder="Your Email" required>
            <textarea placeholder="Your Message" rows="5" required></textarea>
            <button type="submit" class="submit-btn">Send Message</button>
        </form>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>Gold Pouch</h4>
                <p>Premium affiliate marketing and blogging platform</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <a href="#ecommerce">Products</a>
                <a href="#blog">Blog</a>
                <a href="#contact">Contact</a>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <div class="social-links">
                    <a href="#" class="social-link">Twitter</a>
                    <a href="#" class="social-link">Facebook</a>
                    <a href="#" class="social-link">Instagram</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 Gold Pouch. All rights reserved.</p>
        </div>
    </footer>

    <!-- Product Overlay Modal -->
    <div id="productModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeProductOverlay()">&times;</span>
            <div class="modal-body" id="productModalBody"></div>
        </div>
    </div>

    <!-- Blog Overlay Modal -->
    <div id="blogModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeBlogOverlay()">&times;</span>
            <div class="modal-body" id="blogModalBody"></div>
        </div>
    </div>

    <!-- All Products Overlay Modal -->
    <div id="allProductsModal" class="modal">
        <div class="modal-content modal-large">
            <span class="close" onclick="closeEcommerceOverlay()">&times;</span>
            <div class="modal-body" id="allProductsBody"></div>
        </div>
    </div>

    <!-- All Blog Posts Overlay Modal -->
    <div id="allBlogModal" class="modal">
        <div class="modal-content modal-large">
            <span class="close" onclick="closeBlogListOverlay()">&times;</span>
            <div class="modal-body" id="allBlogBody"></div>
        </div>
    </div>

    <script src="js/main.js"></script>
</body>
</html>
