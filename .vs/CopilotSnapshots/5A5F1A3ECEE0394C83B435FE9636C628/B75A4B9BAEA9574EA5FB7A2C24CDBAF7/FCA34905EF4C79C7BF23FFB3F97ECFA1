<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gold Pouch - Premium Affiliate & Lifestyle Blog</title>
    <link rel="stylesheet" href="CSS/styles.css">
    <link rel="stylesheet" href="CSS/animations.css">
    <link rel="stylesheet" href="CSS/responsive.css">
</head>
<body>
    <!-- Background animated elements -->
    <div class="background-container">
        <canvas id="heartbeatCanvas"></canvas>
        <div class="neon-grid"></div>
        <div class="animated-orbs">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>
        </div>
    </div>

    <!-- Header -->
    <header class="header">
        <div class="header-content">
            <div class="logo-wrapper">
                <div class="logo-text">
                    <span class="gold-text">GOLD</span>
                    <span class="heart-icon">❤️</span>
                    <span class="red-text">POUCH</span>
                </div>
                <p class="tagline">Premium Affiliate & Lifestyle Insights</p>
            </div>
            <nav class="nav-menu">
                <a href="#ecommerce" class="nav-link">Shop</a>
                <a href="#blog" class="nav-link">Blog</a>
                <a href="#about" class="nav-link">About</a>
                <a href="#contact" class="nav-link">Contact</a>
            </nav>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1 class="hero-title">
                <span class="title-word" data-word="Elevate">Elevate</span>
                <span class="title-word" data-word="Your">Your</span>
                <span class="title-word" data-word="Lifestyle">Lifestyle</span>
            </h1>
            <p class="hero-subtitle">Curated premium products & exclusive insights for the modern you</p>
            <button class="cta-button primary-btn">Explore Now</button>
        </div>
    </section>

    <!-- E-commerce Section -->
    <section id="ecommerce" class="ecommerce-section">
        <div class="section-header">
            <h2 class="section-title">Curated Collections</h2>
            <p class="section-subtitle">Hand-picked premium products for you</p>
        </div>

        <div class="products-grid">
            <!-- Product 1 -->
            <div class="product-card" data-product="1">
                <div class="product-image">
                    <div class="image-placeholder product-bg-1">
                        <span class="product-icon">💎</span>
                    </div>
                    <span class="product-badge">Premium</span>
                </div>
                <div class="product-info">
                    <h3>Luxury Wellness Kit</h3>
                    <p class="product-desc">Premium self-care essentials</p>
                    <div class="product-price">$99.99</div>
                    <button class="product-btn">View Details</button>
                </div>
            </div>

            <!-- Product 2 -->
            <div class="product-card" data-product="2">
                <div class="product-image">
                    <div class="image-placeholder product-bg-2">
                        <span class="product-icon">✨</span>
                    </div>
                    <span class="product-badge">Exclusive</span>
                </div>
                <div class="product-info">
                    <h3>Elite Skincare Range</h3>
                    <p class="product-desc">Advanced beauty technology</p>
                    <div class="product-price">$149.99</div>
                    <button class="product-btn">View Details</button>
                </div>
            </div>

            <!-- Product 3 -->
            <div class="product-card" data-product="3">
                <div class="product-image">
                    <div class="image-placeholder product-bg-3">
                        <span class="product-icon">🌟</span>
                    </div>
                    <span class="product-badge">Best Seller</span>
                </div>
                <div class="product-info">
                    <h3>Premium Fitness Bundle</h3>
                    <p class="product-desc">Complete wellness solution</p>
                    <div class="product-price">$199.99</div>
                    <button class="product-btn">View Details</button>
                </div>
            </div>
        </div>

        <div class="section-footer">
            <button class="see-more-btn" id="seeMoreEcommerce">
                <span>Explore All Products</span>
                <span class="arrow">→</span>
            </button>
        </div>
    </section>

    <!-- Blog Section -->
    <section id="blog" class="blog-section">
        <div class="section-header">
            <h2 class="section-title">Latest Insights</h2>
            <p class="section-subtitle">Expert tips, trends & lifestyle wisdom</p>
        </div>

        <div class="blog-grid">
            <!-- Blog Post 1 -->
            <article class="blog-card" data-blog="1">
                <div class="blog-image">
                    <div class="image-placeholder blog-bg-1">
                        <span class="blog-icon">📈</span>
                    </div>
                    <span class="blog-category">Finance</span>
                </div>
                <div class="blog-content">
                    <h3>The Art of Wealth Accumulation</h3>
                    <p class="blog-excerpt">Discover proven strategies for building sustainable wealth and financial independence...</p>
                    <div class="blog-meta">
                        <span class="blog-date">Dec 15, 2024</span>
                        <span class="read-time">5 min read</span>
                    </div>
                    <button class="read-btn">Read Article</button>
                </div>
            </article>

            <!-- Blog Post 2 -->
            <article class="blog-card" data-blog="2">
                <div class="blog-image">
                    <div class="image-placeholder blog-bg-2">
                        <span class="blog-icon">💪</span>
                    </div>
                    <span class="blog-category">Wellness</span>
                </div>
                <div class="blog-content">
                    <h3>Premium Lifestyle Habits</h3>
                    <p class="blog-excerpt">Transform your daily routine with elite habits practiced by industry leaders and innovators...</p>
                    <div class="blog-meta">
                        <span class="blog-date">Dec 12, 2024</span>
                        <span class="read-time">7 min read</span>
                    </div>
                    <button class="read-btn">Read Article</button>
                </div>
            </article>

            <!-- Blog Post 3 -->
            <article class="blog-card" data-blog="3">
                <div class="blog-image">
                    <div class="image-placeholder blog-bg-3">
                        <span class="blog-icon">🎯</span>
                    </div>
                    <span class="blog-category">Growth</span>
                </div>
                <div class="blog-content">
                    <h3>Mastering Your Personal Brand</h3>
                    <p class="blog-excerpt">Build an authentic brand that resonates with your audience and opens doors to opportunities...</p>
                    <div class="blog-meta">
                        <span class="blog-date">Dec 10, 2024</span>
                        <span class="read-time">6 min read</span>
                    </div>
                    <button class="read-btn">Read Article</button>
                </div>
            </article>
        </div>

        <div class="section-footer">
            <button class="see-more-btn" id="seeMoreBlog">
                <span>View All Articles</span>
                <span class="arrow">→</span>
            </button>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about-section">
        <div class="about-content">
            <h2>About Gold Pouch</h2>
            <p>Welcome to Gold Pouch, your destination for premium lifestyle products and exclusive insights. We believe in quality over quantity, and every recommendation is carefully curated to meet the highest standards.</p>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact-section">
        <div class="contact-content">
            <h2>Get In Touch</h2>
            <p>Have questions? We'd love to hear from you.</p>
            <button class="cta-button primary-btn">Contact Us</button>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>Gold Pouch</h4>
                <p>Premium affiliate marketing and blogging platform</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <a href="#ecommerce">Products</a>
                <a href="#blog">Blog</a>
                <a href="#contact">Contact</a>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <div class="social-links">
                    <a href="#" class="social-link">Twitter</a>
                    <a href="#" class="social-link">Facebook</a>
                    <a href="#" class="social-link">Instagram</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2024 Gold Pouch. All rights reserved.</p>
        </div>
    </footer>

    <!-- Product Overlay Modal -->
    <div id="productModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeProductOverlay()">&times;</span>
            <div class="modal-body" id="productModalBody"></div>
        </div>
    </div>

    <!-- Blog Overlay Modal -->
    <div id="blogModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeBlogOverlay()">&times;</span>
            <div class="modal-body" id="blogModalBody"></div>
        </div>
    </div>

    <!-- All Products Overlay Modal -->
    <div id="allProductsModal" class="modal">
        <div class="modal-content modal-large">
            <span class="close" onclick="closeEcommerceOverlay()">&times;</span>
            <div class="modal-body" id="allProductsBody"></div>
        </div>
    </div>

    <!-- All Blog Posts Overlay Modal -->
    <div id="allBlogModal" class="modal">
        <div class="modal-content modal-large">
            <span class="close" onclick="closeBlogListOverlay()">&times;</span>
            <div class="modal-body" id="allBlogBody"></div>
        </div>
    </div>

    <script src="js/main.js"></script>
</body>
</html>
