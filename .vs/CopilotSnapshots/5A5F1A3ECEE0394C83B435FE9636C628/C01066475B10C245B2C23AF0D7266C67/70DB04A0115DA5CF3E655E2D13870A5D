/* ==========================================
   GOLD POUCH - PREMIUM WEBSITE STYLES
   Elite, Premium, Adobe-Quality Design
   ========================================== */

/* ===== ROOT VARIABLES ===== */
:root {
    /* Color Palette */
    --gold-primary: #FFD700;
    --gold-secondary: #D4AF37;
    --gold-dark: #B8860B;
    --red-primary: #DC143C;
    --red-accent: #FF6B6B;
    --white: #FFFFFF;
    --dark: #0F0F0F;
    --dark-secondary: #1A1A1A;
    --text-primary: #F5F5F5;
    --text-secondary: #B0B0B0;

    /* Effects */
    --neon-red: #FF0080;
    --neon-gold: #FFD700;
    --glow-strength: 0 0 20px;

    /* Spacing */
    --spacing-xs: 0.5rem;
    --spacing-sm: 1rem;
    --spacing-md: 2rem;
    --spacing-lg: 3rem;
    --spacing-xl: 4rem;

    /* Transitions */
    --transition-fast: 0.2s ease;
    --transition-normal: 0.4s ease;
    --transition-slow: 0.8s ease;
}

/* ===== GLOBAL STYLES ===== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #0F0F0F 0%, #1A1A1A 50%, #2D1B2E 100%);
    color: var(--text-primary);
    overflow-x: hidden;
    position: relative;
}

/* ===== BACKGROUND CONTAINER ===== */
.background-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
}

#heartbeatCanvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}

.neon-grid {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: 
        linear-gradient(0deg, rgba(220, 20, 60, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 215, 0, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 20s linear infinite;
    pointer-events: none;
}

@keyframes gridMove {
    0% { transform: translateY(0); }
    100% { transform: translateY(50px); }
}

/* Animated Orbs */
.animated-orbs {
    position: absolute;
    width: 100%;
    height: 100%;
    pointer-events: none;
}

.orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.3;
    mix-blend-mode: screen;
}

.orb-1 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #FFD700, transparent);
    top: 10%;
    left: 10%;
    animation: float 15s ease-in-out infinite;
}

.orb-2 {
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, #DC143C, transparent);
    top: 50%;
    right: 10%;
    animation: float 18s ease-in-out infinite reverse;
}

.orb-3 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, #FF6B6B, transparent);
    bottom: 10%;
    left: 50%;
    animation: float 12s ease-in-out infinite;
}

@keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, 30px); }
}

/* ===== HEADER ===== */
.header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 15, 15, 0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 215, 0, 0.1);
    padding: var(--spacing-md) 0;
    animation: slideDown 0.6s ease-out;
}

@keyframes slideDown {
    from {
        transform: translateY(-100%);
        opacity: 0;
    }
    to {
        transform: translateY(0);
        opacity: 1;
    }
}

.header-content {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
}

.logo-text {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 1.8rem;
    font-weight: 900;
    letter-spacing: 2px;
}

.gold-text {
    background: linear-gradient(90deg, #FFD700, #D4AF37);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5));
}

.red-text {
    background: linear-gradient(90deg, #DC143C, #FF6B6B);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 10px rgba(220, 20, 60, 0.5));
}

.heart-icon {
    font-size: 1.5rem;
    animation: heartBeat 1.5s ease-in-out infinite;
}

@keyframes heartBeat {
    0%, 100% { transform: scale(1); }
    25% { transform: scale(1.2); }
    50% { transform: scale(1); }
}

.tagline {
    font-size: 0.75rem;
    color: var(--text-secondary);
    letter-spacing: 1px;
    text-transform: uppercase;
}

/* Navigation Menu */
.nav-menu {
    display: flex;
    gap: var(--spacing-lg);
    align-items: center;
}

.nav-link {
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    position: relative;
    transition: var(--transition-fast);
    letter-spacing: 0.5px;
}

.nav-link::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #FFD700, #DC143C);
    transition: width var(--transition-normal);
    box-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
}

.nav-link:hover {
    color: var(--gold-primary);
    text-shadow: 0 0 15px rgba(255, 215, 0, 0.5);
}

.nav-link:hover::after {
    width: 100%;
}

/* ===== HERO SECTION ===== */
.hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-xl) var(--spacing-lg);
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 215, 0, 0.1) 0%, transparent 70%);
    animation: heroGlow 8s ease-in-out infinite;
}

@keyframes heroGlow {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(20px, 20px) scale(1.1); }
}

.hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    animation: heroFadeIn 1s ease-out 0.3s both;
}

@keyframes heroFadeIn {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.hero-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: var(--spacing-md);
    letter-spacing: -1px;
}

.title-word {
    display: inline-block;
    background: linear-gradient(135deg, #FFD700, #DC143C, #FFD700);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: titleGradient 3s ease infinite;
    filter: drop-shadow(0 0 20px rgba(255, 215, 0, 0.3));
    margin: 0 var(--spacing-xs);
}

@keyframes titleGradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
}

.hero-subtitle {
    font-size: 1.3rem;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
    font-weight: 300;
    letter-spacing: 0.5px;
}

/* ===== BUTTONS ===== */
.cta-button {
    padding: 1rem 2.5rem;
    font-size: 1rem;
    font-weight: 700;
    border: 2px solid var(--gold-primary);
    background: linear-gradient(135deg, var(--gold-primary), var(--red-primary));
    color: var(--dark);
    border-radius: 50px;
    cursor: pointer;
    transition: all var(--transition-normal);
    letter-spacing: 1px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
    text-transform: uppercase;
}

.cta-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.2);
    transition: left var(--transition-normal);
}

.cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(255, 215, 0, 0.4), 0 0 30px rgba(220, 20, 60, 0.3);
}

.cta-button:hover::before {
    left: 100%;
}

.primary-btn {
    background: linear-gradient(135deg, #FFD700, #D4AF37);
    border-color: #FFD700;
}

/* ===== SECTIONS ===== */
section {
    padding: var(--spacing-xl) var(--spacing-lg);
    max-width: 1400px;
    margin: 0 auto;
}

.section-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
    animation: slideUp 0.6s ease-out;
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    margin-bottom: var(--spacing-sm);
    background: linear-gradient(90deg, #FFD700, #DC143C);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 1px;
}

.section-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-weight: 300;
    letter-spacing: 0.5px;
}

/* ===== E-COMMERCE SECTION ===== */
.ecommerce-section {
    background: linear-gradient(135deg, rgba(30, 15, 20, 0.5), rgba(25, 20, 30, 0.5));
    border-radius: 20px;
    margin: var(--spacing-xl) auto;
    padding: var(--spacing-xl);
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
}

.product-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 215, 0, 0.1);
    border-radius: 15px;
    overflow: hidden;
    transition: all var(--transition-normal);
    cursor: pointer;
    position: relative;
    animation: cardFadeIn 0.6s ease-out both;
}

.product-card:nth-child(1) { animation-delay: 0.1s; }
.product-card:nth-child(2) { animation-delay: 0.2s; }
.product-card:nth-child(3) { animation-delay: 0.3s; }

@keyframes cardFadeIn {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.product-card:hover {
    border-color: rgba(255, 215, 0, 0.3);
    box-shadow: 0 0 30px rgba(255, 215, 0, 0.2), inset 0 0 20px rgba(255, 215, 0, 0.05);
    transform: translateY(-10px);
}

.product-image {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
}

.image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background-size: cover;
    background-position: center;
    transition: all var(--transition-normal);
    position: relative;
}

.product-card:hover .image-placeholder {
    transform: scale(1.1) rotate(2deg);
}

.product-bg-1 {
    background: linear-gradient(135deg, #FFD700, #D4AF37, #B8860B);
}

.product-bg-2 {
    background: linear-gradient(135deg, #D4AF37, #DC143C, #FF6B6B);
}

.product-bg-3 {
    background: linear-gradient(135deg, #DC143C, #FF0080, #FFD700);
}

.product-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    background: rgba(0, 0, 0, 0.7);
    color: var(--gold-primary);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid var(--gold-primary);
    box-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
}

.product-info {
    padding: var(--spacing-md);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.5));
}

.product-info h3 {
    font-size: 1.2rem;
    margin-bottom: var(--spacing-xs);
    color: var(--white);
}

.product-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: var(--spacing-sm);
    line-height: 1.5;
}

.product-price {
    font-size: 1.5rem;
    font-weight: 900;
    background: linear-gradient(90deg, #FFD700, #DC143C);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--spacing-sm);
}

.product-btn {
    width: 100%;
    padding: 0.8rem;
    background: linear-gradient(90deg, rgba(255, 215, 0, 0.2), rgba(220, 20, 60, 0.2));
    border: 1px solid rgba(255, 215, 0, 0.3);
    color: var(--gold-primary);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all var(--transition-normal);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.product-btn:hover {
    background: linear-gradient(90deg, var(--gold-primary), var(--red-primary));
    color: var(--dark);
    box-shadow: 0 0 15px rgba(255, 215, 0, 0.4);
}

/* ===== BLOG SECTION ===== */
.blog-section {
    background: linear-gradient(135deg, rgba(20, 25, 30, 0.5), rgba(30, 15, 20, 0.5));
    border-radius: 20px;
    margin: var(--spacing-xl) auto;
    padding: var(--spacing-xl);
}

.blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
}

.blog-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(220, 20, 60, 0.1);
    border-radius: 15px;
    overflow: hidden;
    transition: all var(--transition-normal);
    display: flex;
    flex-direction: column;
    animation: cardFadeIn 0.6s ease-out both;
}

.blog-card:nth-child(1) { animation-delay: 0.1s; }
.blog-card:nth-child(2) { animation-delay: 0.2s; }
.blog-card:nth-child(3) { animation-delay: 0.3s; }

.blog-card:hover {
    border-color: rgba(220, 20, 60, 0.3);
    box-shadow: 0 0 30px rgba(220, 20, 60, 0.2), inset 0 0 20px rgba(220, 20, 60, 0.05);
    transform: translateY(-10px);
}

.blog-image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
}

.blog-bg-1 {
    background: linear-gradient(135deg, #FFD700, #D4AF37, #B8860B);
}

.blog-bg-2 {
    background: linear-gradient(135deg, #D4AF37, #DC143C, #FF6B6B);
}

.blog-bg-3 {
    background: linear-gradient(135deg, #DC143C, #FF0080, #FFD700);
}

.blog-card:hover .image-placeholder {
    transform: scale(1.1);
}

.blog-category {
    position: absolute;
    top: 15px;
    left: 15px;
    background: rgba(220, 20, 60, 0.9);
    color: var(--white);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    box-shadow: 0 0 15px rgba(220, 20, 60, 0.5);
}

.blog-content {
    padding: var(--spacing-md);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.5));
    flex-grow: 1;
    display: flex;
    flex-direction: column;
}

.blog-content h3 {
    font-size: 1.2rem;
    margin-bottom: var(--spacing-sm);
    color: var(--white);
    line-height: 1.4;
}

.blog-excerpt {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
    flex-grow: 1;
}

.blog-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: auto;
    padding-top: var(--spacing-sm);
    border-top: 1px solid rgba(255, 215, 0, 0.1);
}

.read-btn {
    margin-top: var(--spacing-sm);
    padding: 0.8rem 1.5rem;
    background: linear-gradient(90deg, rgba(220, 20, 60, 0.2), rgba(255, 215, 0, 0.2));
    border: 1px solid rgba(220, 20, 60, 0.3);
    color: var(--red-primary);
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
    transition: all var(--transition-normal);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    align-self: flex-start;
}

.read-btn:hover {
    background: linear-gradient(90deg, var(--red-primary), var(--gold-primary));
    color: var(--dark);
    box-shadow: 0 0 15px rgba(220, 20, 60, 0.4);
}

/* ===== SECTION FOOTER ===== */
.section-footer {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
}

.see-more-btn {
    padding: 1rem 2rem;
    background: rgba(255, 215, 0, 0.1);
    border: 2px solid rgba(255, 215, 0, 0.3);
    color: var(--gold-primary);
    border-radius: 50px;
    cursor: pointer;
    font-weight: 700;
    font-size: 1rem;
    transition: all var(--transition-normal);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    letter-spacing: 1px;
    text-transform: uppercase;
}

.see-more-btn:hover {
    background: var(--gold-primary);
    color: var(--dark);
    box-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
    transform: translateY(-3px);
}

.see-more-btn .arrow {
    transition: transform var(--transition-normal);
}

.see-more-btn:hover .arrow {
    transform: translateX(5px);
}

/* ===== ABOUT SECTION ===== */
.about-section {
    text-align: center;
    padding: var(--spacing-xl);
    background: rgba(255, 215, 0, 0.05);
    border-radius: 20px;
    border: 1px solid rgba(255, 215, 0, 0.1);
    margin: var(--spacing-xl) auto;
}

.about-section h2 {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
    background: linear-gradient(90deg, #FFD700, #DC143C);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.about-section p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto;
}

/* ===== CONTACT SECTION ===== */
.contact-section {
    background: linear-gradient(135deg, rgba(30, 15, 20, 0.5), rgba(25, 20, 30, 0.5));
    border-radius: 20px;
    margin: var(--spacing-xl) auto;
    padding: var(--spacing-xl);
    text-align: center;
}

.contact-section h2 {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-sm);
    background: linear-gradient(90deg, #FFD700, #DC143C);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.contact-section p {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
}

/* ===== FOOTER ===== */
.footer {
    background: rgba(0, 0, 0, 0.8);
    border-top: 1px solid rgba(255, 215, 0, 0.1);
    padding: var(--spacing-lg) 0;
    margin-top: var(--spacing-xl);
}

.footer-content {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
}

.footer-content p {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.social-links {
    display: flex;
    gap: var(--spacing-md);
}

.social-link {
    color: var(--gold-primary);
    text-decoration: none;
    transition: all var(--transition-normal);
    font-weight: 600;
    font-size: 0.85rem;
}

.social-link:hover {
    color: var(--red-primary);
    text-shadow: 0 0 10px rgba(220, 20, 60, 0.5);
}

/* ===== MODALS ===== */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(5px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease-out;
}

.modal.active {
    display: flex;
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

.modal-content {
    background: linear-gradient(135deg, #1A1A1A, #2D1B2E);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 20px;
    max-width: 700px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    animation: slideIn 0.4s ease-out;
    box-shadow: 0 0 50px rgba(255, 215, 0, 0.2);
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: scale(0.9) translateY(30px);
    }
    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(255, 215, 0, 0.1);
    border: 2px solid var(--gold-primary);
    color: var(--gold-primary);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-normal);
    z-index: 10;
}

.modal-close:hover {
    background: var(--gold-primary);
    color: var(--dark);
    transform: rotate(90deg);
}

.modal-body {
    padding: var(--spacing-lg);
}

.modal-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, #FFD700, #DC143C);
    border-radius: 15px;
    margin-bottom: var(--spacing-md);
}

.modal-details h2,
.modal-article h2 {
    font-size: 1.8rem;
    margin-bottom: var(--spacing-sm);
    color: var(--white);
}

.modal-details p,
.modal-article-content {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--spacing-md);
}

.modal-price {
    font-size: 1.8rem;
    font-weight: 900;
    background: linear-gradient(90deg, #FFD700, #DC143C);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--spacing-lg);
}

.modal-meta {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: var(--spacing-md);
    display: flex;
    gap: var(--spacing-sm);
}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar {
    width: 10px;
}

::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.5);
}

::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, #FFD700, #DC143C);
    border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, #D4AF37, #FF6B6B);
}

/* ===== UTILITY CLASSES ===== */
.glow-text {
    text-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
}

.glow-box {
    box-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
}

/* ===== LOADING STATE ===== */
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

.loading {
    animation: pulse 1.5s ease-in-out infinite;
}
